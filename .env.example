# ─── DATABASE ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/owambe
REDIS_URL=redis://localhost:6379

# ─── AUTH ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── PAYSTACK ────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ─── AI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ─── STORAGE ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=owambe-media
AWS_REGION=af-south-1

# ─── EMAIL ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@owambe.com
EMAIL_FROM_NAME=Owambe

# ─── SMS ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=xxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+234xxxxxxxxxx

# ─── APP ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://owambe.com
NEXT_PUBLIC_API_URL=https://api.owambe.com
API_PORT=4000
NODE_ENV=development

# ─── MAPS ────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=xxxxxxxxxxxxxxxxxxxx
