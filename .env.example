# ─── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/owambe
REDIS_URL=redis://localhost:6379

# ─── AUTH ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── PAYSTACK ─────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ─── AI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ─── STORAGE (AWS S3) ─────────────────────────────────
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=owambe-media
AWS_REGION=af-south-1

# ─── EMAIL (SendGrid) ─────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@owambe.com
EMAIL_FROM_NAME=Owambe

# ─── SMS (Twilio — optional) ──────────────────────────
TWILIO_ACCOUNT_SID=xxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+234xxxxxxxxxx

# ─── APP URLS ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://owambe.com
NEXT_PUBLIC_API_URL=https://api.owambe.com
WHITELABEL_URL=https://portal.owambe.com
API_PORT=4000
NODE_ENV=production

# ─── MAPS (Google — optional) ─────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=xxxxxxxxxxxxxxxxxxxx

# ─── MOBILE (Expo) ────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.owambe.com/api
EXPO_PUBLIC_APP_ENV=production

# ─── WHITE-LABEL PORTAL (Vercel whitelabel app) ───────
OWAMBE_API_URL=https://api.owambe.com/api
OWAMBE_MAIN_URL=https://owambe.com

# ─── GENERATE SECRETS ─────────────────────────────────
# JWT_SECRET:     openssl rand -base64 32
# Webhook secret: openssl rand -hex 32

# ─── CRM INTEGRATIONS (Scale plan only) ───────────────
SF_CLIENT_ID=your-salesforce-connected-app-client-id
SF_CLIENT_SECRET=your-salesforce-connected-app-client-secret
HS_CLIENT_ID=your-hubspot-app-client-id
HS_CLIENT_SECRET=your-hubspot-app-client-secret

# ─── CRON JOBS ──────────────────────────────────────
CRON_SECRET=generate-with-openssl-rand-hex-32
