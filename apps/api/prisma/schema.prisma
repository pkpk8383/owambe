// ─────────────────────────────────────────────────────
// Owambe.com — Prisma Database Schema
// PostgreSQL + PostGIS for geo-queries
// ─────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp]
}

// ─── ENUMS ───────────────────────────────────────────

enum UserRole {
  PLANNER
  VENDOR
  CONSUMER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  ENDED
  CANCELLED
}

enum EventFormat {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum BookingType {
  INSTANT
  RFQ
}

enum VendorCategory {
  VENUE
  CATERING
  AV_PRODUCTION
  PHOTOGRAPHY_VIDEO
  DECOR_FLORALS
  ENTERTAINMENT
  MAKEUP_ARTIST
  SPEAKER
}

enum VendorStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  FULLY_PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

enum ContractStatus {
  DRAFT
  SENT
  PARTIALLY_SIGNED
  FULLY_SIGNED
  VOID
  EXPIRED
}

enum SignerRole {
  PLANNER
  VENDOR
  WITNESS
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TicketStatus {
  ACTIVE
  SOLD_OUT
  PAUSED
}

enum CheckInStatus {
  REGISTERED
  CHECKED_IN
  NO_SHOW
}

enum SpeakerStatus {
  INVITED
  CONFIRMED
  DECLINED
  PENDING
}

enum SponsorTier {
  GOLD
  SILVER
  BRONZE
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  QUOTE_RECEIVED
  MESSAGE_RECEIVED
  EVENT_REMINDER
  REVIEW_RECEIVED
  VENDOR_VERIFIED
}

enum PlanType {
  STARTER
  GROWTH
  SCALE
}

// ─── USERS ───────────────────────────────────────────

model User {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email            String       @unique
  passwordHash     String?
  role             UserRole
  authProvider     AuthProvider @default(EMAIL)
  providerUserId   String?
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  isEmailVerified  Boolean      @default(false)
  isPhoneVerified  Boolean      @default(false)
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  planner          Planner?
  vendor           Vendor?
  consumer         Consumer?
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  sentMessages     Message[]    @relation("SentMessages")
  receivedMessages Message[]    @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

// ─── PLANNER ─────────────────────────────────────────

model Planner {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @unique @db.Uuid
  companyName  String?
  plan         PlanType @default(STARTER)
  planExpiresAt DateTime?
  paystackCustomerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  bookings     Booking[]
  tenants      Tenant[]
  contracts    Contract[]
  crmConnections CrmConnection[]
  instalmentPlans InstalmentPlan[]

  @@map("planners")
}

// ─── WHITE-LABEL TENANT ──────────────────────────────
model Tenant {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  plannerId       String   @db.Uuid
  subdomain       String   @unique
  customDomain    String?  @unique
  name            String
  tagline         String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#2D6A4F")
  accentColor     String   @default("#E76F2A")
  bgColor         String   @default("#FDFAF4")
  fontFamily      String   @default("Inter")
  footerText      String?
  socialLinks     Json?
  metaTitle       String?
  metaDescription String?
  metaImage       String?
  isActive        Boolean  @default(true)
  allowPublicReg  Boolean  @default(true)
  requireApproval Boolean  @default(false)
  customCss       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  planner  Planner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@map("tenants")
}

// ─── VENDOR ──────────────────────────────────────────

model Vendor {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId              String         @unique @db.Uuid
  businessName        String
  slug                String         @unique
  category            VendorCategory
  subCategories       String[]
  description         String?
  shortBio            String?
  status              VendorStatus   @default(PENDING)
  isInstantBook       Boolean        @default(false)
  minPrice            Decimal?       @db.Decimal(12, 2)
  maxPrice            Decimal?       @db.Decimal(12, 2)
  currency            String         @default("NGN")
  commissionRate      Decimal        @default(8) @db.Decimal(5, 2)
  rating              Decimal        @default(0) @db.Decimal(3, 2)
  reviewCount         Int            @default(0)
  responseRate        Decimal        @default(0) @db.Decimal(5, 2)
  bookingCount        Int            @default(0)
  // Location
  address             String?
  city                String?
  state               String?
  country             String         @default("Nigeria")
  latitude            Decimal?       @db.Decimal(10, 8)
  longitude           Decimal?       @db.Decimal(11, 8)
  serviceRadius       Int            @default(30) // km
  // Business details
  businessRegNo       String?
  paystackSubAccountCode String?
  paystackSubAccountId   String?
  bankAccountName     String?
  bankCode            String?
  bankAccountNumber   String?
  isFeatured          Boolean        @default(false)
  featuredUntil       DateTime?
  launchBonusActive   Boolean        @default(true)
  launchBonusExpiresAt DateTime?
  verifiedAt          DateTime?
  rejectionReason     String?
  phone               String?
  isPhoneVerified     Boolean        @default(false)
  website             String?
  instagram           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioItems      PortfolioItem[]
  availability        VendorAvailability[]
  bookings            Booking[]
  reviews             Review[]
  packages            VendorPackage[]
  quotes              Quote[]
  contracts           Contract[]

  @@index([category])
  @@index([status])
  @@index([city])
  @@index([isInstantBook])
  @@map("vendors")
}

model PortfolioItem {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId    String   @db.Uuid
  url         String
  thumbnailUrl String?
  caption     String?
  isMain      Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}

model VendorPackage {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId    String   @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("NGN")
  duration    String?
  includes    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("vendor_packages")
}

model VendorAvailability {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId    String   @db.Uuid
  date        DateTime @db.Date
  isAvailable Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, date])
  @@index([vendorId, date])
  @@map("vendor_availability")
}

// ─── CONSUMER ────────────────────────────────────────

model Consumer {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String   @unique @db.Uuid
  city              String?
  state             String?
  loyaltyCredits    Decimal  @default(0) @db.Decimal(12, 2)
  paystackCustomerId String?
  aiPreferences     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  aiPlans  AiEventPlan[]

  instalmentPlans InstalmentPlan[]

  @@map("consumers")
}

// ─── EVENTS ──────────────────────────────────────────

model Event {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  plannerId     String      @db.Uuid
  name          String
  slug          String      @unique
  description   String?
  type          String
  format        EventFormat @default(IN_PERSON)
  status        EventStatus @default(DRAFT)
  startDate     DateTime
  endDate       DateTime?
  venue         String?
  address       String?
  city          String?
  maxCapacity   Int?
  coverImageUrl String?
  isPublic      Boolean     @default(true)
  metaTitle     String?
  metaDesc      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  planner       Planner     @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  ticketTypes   TicketType[]
  attendees     Attendee[]
  speakers      Speaker[]
  sponsors      EventSponsor[]
  emailCampaigns EmailCampaign[]
  checkIns      CheckIn[]

  @@index([plannerId])
  @@index([status])
  @@index([startDate])
  @@map("events")
}

model TicketType {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId      String       @db.Uuid
  name         String
  description  String?
  price        Decimal      @db.Decimal(12, 2)
  currency     String       @default("NGN")
  capacity     Int?
  soldCount    Int          @default(0)
  status       TicketStatus @default(ACTIVE)
  saleStartsAt DateTime?
  saleEndsAt   DateTime?
  salesEndDate DateTime?    // alias kept for backward compat
  minPerOrder  Int          @default(1)
  maxPerOrder  Int          @default(10)
  benefits     String[]     @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendees Attendee[]

  @@index([eventId])
  @@map("ticket_types")
}

model Attendee {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId        String        @db.Uuid
  ticketTypeId   String        @db.Uuid
  firstName      String
  lastName       String
  email          String
  phone          String?
  company        String?
  qrCode         String        @unique
  status         CheckInStatus @default(REGISTERED)
  promoCode      String?
  amountPaid     Decimal       @db.Decimal(12, 2)
  paystackRef    String?
  registeredAt   DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  checkIn    CheckIn?

  @@index([eventId])
  @@index([email])
  @@index([qrCode])
  @@map("attendees")
}

model CheckIn {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String   @db.Uuid
  attendeeId  String   @unique @db.Uuid
  checkedInAt DateTime @default(now())
  checkedInBy String?

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("check_ins")
}

model PromoCode {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId       String   @db.Uuid
  code          String
  discountType  String   // PERCENTAGE | FIXED
  discountValue Decimal  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([eventId, code])
  @@map("promo_codes")
}

// ─── SPEAKERS ────────────────────────────────────────

model Speaker {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String        @db.Uuid
  name        String
  title       String?
  company     String?
  email       String?
  bio         String?
  photoUrl    String?
  linkedinUrl String?
  topic       String?
  track       String?
  sessionTime DateTime?
  room        String?
  travelNeeds String?
  status      SpeakerStatus @default(INVITED)
  checklistInvited   Boolean @default(true)
  checklistConfirmed Boolean @default(false)
  checklistBio       Boolean @default(false)
  checklistPhoto     Boolean @default(false)
  checklistSession   Boolean @default(false)
  checklistSlides    Boolean @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("speakers")
}

// ─── SPONSORS ────────────────────────────────────────

model EventSponsor {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String      @db.Uuid
  name        String
  logoUrl     String?
  tier        SponsorTier @default(BRONZE)
  amount      Decimal     @db.Decimal(12, 2)
  perks       String?
  contactEmail String?
  createdAt   DateTime    @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_sponsors")
}

// ─── EMAIL CAMPAIGNS ─────────────────────────────────

model EmailCampaign {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String   @db.Uuid
  name        String
  subject     String
  body        String
  audience    String   // ALL | VIP | NOT_REGISTERED | WAITLIST
  status      String   @default("DRAFT") // DRAFT | SCHEDULED | SENT
  scheduledAt DateTime?
  sentAt      DateTime?
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  recipientCount Int   @default(0)
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("email_campaigns")
}

// ─── BOOKINGS ────────────────────────────────────────

model Booking {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference        String        @unique
  vendorId         String        @db.Uuid
  plannerId        String?       @db.Uuid
  consumerId       String?       @db.Uuid
  packageId        String?       @db.Uuid
  bookingType      BookingType
  status           BookingStatus @default(PENDING)
  eventDate        DateTime
  eventDescription String?
  guestCount       Int?
  totalAmount      Decimal       @db.Decimal(12, 2)
  depositAmount    Decimal       @db.Decimal(12, 2)
  commissionAmount Decimal       @db.Decimal(12, 2)
  vendorAmount     Decimal       @db.Decimal(12, 2)
  currency         String        @default("NGN")
  paymentStatus    PaymentStatus @default(PENDING)
  depositPaidAt    DateTime?
  balancePaidAt    DateTime?
  payoutReleasedAt DateTime?
  paystackDepositRef  String?
  paystackBalanceRef  String?
  cancellationReason  String?
  cancelledAt         DateTime?
  completedAt         DateTime?
  bookerEmail      String?
  bookerName       String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vendor   Vendor        @relation(fields: [vendorId], references: [id])
  planner  Planner?      @relation(fields: [plannerId], references: [id])
  consumer Consumer?     @relation(fields: [consumerId], references: [id])
  package  VendorPackage? @relation(fields: [packageId], references: [id])
  quote    Quote?
  review   Review?
  messages Message[]

  @@index([vendorId])
  @@index([plannerId])
  @@index([consumerId])
  @@index([status])
  @@index([eventDate])

  contracts Contract[]
  instalmentPlans InstalmentPlan[]

  @@map("bookings")
}

model Quote {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId   String      @unique @db.Uuid
  vendorId    String      @db.Uuid
  lineItems   Json
  totalAmount Decimal     @db.Decimal(12, 2)
  validUntil  DateTime
  notes       String?
  status      QuoteStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@map("quotes")
}

// ─── REVIEWS ─────────────────────────────────────────

model Review {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId   String   @db.Uuid
  bookingId  String   @unique @db.Uuid
  rating     Int
  title      String?
  body       String?
  response   String?
  respondedAt DateTime?
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())

  vendor  Vendor  @relation(fields: [vendorId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([vendorId])
  @@map("reviews")
}

// ─── MESSAGES ────────────────────────────────────────

model Message {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId  String   @db.Uuid
  senderId   String   @db.Uuid
  receiverId String   @db.Uuid
  body       String
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender   User    @relation("SentMessages", fields: [senderId], references: [id])
  receiver User    @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

// ─── NOTIFICATIONS ────────────────────────────────────

model Notification {
  id        String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── AI EVENT PLANS ───────────────────────────────────

model AiEventPlan {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  consumerId   String   @db.Uuid
  sessionId    String   @unique
  eventType    String
  location     String
  city         String
  date         DateTime
  guestCount   Int
  totalBudget  Decimal  @db.Decimal(12, 2)
  currency     String   @default("NGN")
  preferences  Json?
  budgetSplit  Json?
  plans        Json?
  selectedPlan String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@index([consumerId])
  @@map("ai_event_plans")
}

// ─── WAITLIST ─────────────────────────────────────────

model Waitlist {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId      String   @db.Uuid
  ticketTypeId String   @db.Uuid
  email        String
  firstName    String
  lastName     String
  notifiedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([eventId, email])
  @@index([eventId])
  @@map("waitlist")
}

// ─── CONTRACTS ───────────────────────────────────────
model Contract {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference       String         @unique
  bookingId       String?        @db.Uuid
  plannerId       String         @db.Uuid
  vendorId        String         @db.Uuid
  title           String
  templateType    String         // SERVICE_AGREEMENT | VENUE_HIRE | PHOTOGRAPHY | CUSTOM
  status          ContractStatus @default(DRAFT)
  bodyHtml        String         // The contract body (HTML/rich text)
  pdfUrl          String?        // Generated PDF stored in S3
  totalAmount     Decimal?       @db.Decimal(12, 2)
  currency        String         @default("NGN")
  eventDate       DateTime?
  eventVenue      String?
  expiresAt       DateTime?
  voidedAt        DateTime?
  voidReason      String?
  sentAt          DateTime?
  fullySignedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  planner    Planner            @relation(fields: [plannerId], references: [id])
  vendor     Vendor             @relation(fields: [vendorId], references: [id])
  booking    Booking?           @relation(fields: [bookingId], references: [id])
  signatures ContractSignature[]

  @@map("contracts")
}

model ContractSignature {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contractId   String     @db.Uuid
  signerRole   SignerRole
  signerName   String
  signerEmail  String
  signedAt     DateTime?
  signingToken String     @unique  // Secure token for signing link
  tokenExpiry  DateTime
  ipAddress    String?
  userAgent    String?
  signatureData String?  // Base64 drawn signature or typed name
  isSigned     Boolean  @default(false)
  viewedAt     DateTime?
  reminderSentAt DateTime?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_signatures")
}

// ─── CRM INTEGRATION ─────────────────────────────────
enum CrmProvider {
  SALESFORCE
  HUBSPOT
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
  PARTIAL
}

enum SyncDirection {
  PUSH        // Owambe → CRM
  PULL        // CRM → Owambe
  BIDIRECTIONAL
}

model CrmConnection {
  id                String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  plannerId         String      @db.Uuid
  provider          CrmProvider
  isActive          Boolean     @default(true)

  // OAuth tokens (encrypted at rest in production)
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  instanceUrl       String?     // Salesforce org URL e.g. https://myorg.my.salesforce.com
  portalId          String?     // HubSpot portal/hub ID

  // Sync configuration
  syncDirection     SyncDirection @default(BIDIRECTIONAL)
  syncAttendees     Boolean     @default(true)
  syncBookings      Boolean     @default(true)
  syncContacts      Boolean     @default(true)
  autoSyncEnabled   Boolean     @default(true)
  syncIntervalHours Int         @default(6)

  // Field mapping (JSON): { owambeField: crmField }
  attendeeFieldMap  Json        @default("{}")
  bookingFieldMap   Json        @default("{}")

  // CRM object IDs for tracking
  crmContactOwnerId String?     // Assign synced contacts to this CRM user
  crmPipelineId     String?     // HubSpot pipeline / SF opportunity stage

  // State
  lastSyncAt        DateTime?
  lastSyncStatus    SyncStatus  @default(IDLE)
  lastSyncError     String?
  totalSynced       Int         @default(0)
  totalErrors       Int         @default(0)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  planner  Planner      @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  syncLogs CrmSyncLog[]

  @@unique([plannerId, provider])
  @@map("crm_connections")
}

model CrmSyncLog {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  connectionId    String        @db.Uuid
  entityType      String        // "attendee" | "booking" | "contact"
  entityId        String        // Owambe entity UUID
  crmId           String?       // CRM record ID after sync
  direction       SyncDirection
  status          SyncStatus
  errorMessage    String?
  payload         Json?         // What was sent/received
  durationMs      Int?
  syncedAt        DateTime      @default(now())

  connection CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([entityType, entityId])
  @@index([syncedAt])
  @@map("crm_sync_logs")
}

// ─── INSTALMENT PAYMENT PLANS ────────────────────────
enum InstalmentStatus {
  ACTIVE       // Plan running, instalments being collected
  COMPLETED    // All instalments paid
  DEFAULTED    // Payment failed and not recovered
  CANCELLED    // User cancelled
  PAUSED       // Temporarily paused (e.g. card expired)
}

enum InstalmentPaymentStatus {
  SCHEDULED    // Future payment, not yet due
  PENDING      // Due soon (within 3 days)
  PROCESSING   // Charge initiated
  PAID         // Successfully collected
  FAILED       // Charge failed
  WAIVED       // Manually waived
}

model InstalmentPlan {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference           String          @unique  // e.g. INST-XXXXX
  bookingId           String          @db.Uuid
  plannerId           String?         @db.Uuid
  consumerId          String?         @db.Uuid

  // Plan configuration
  totalAmount         Decimal         @db.Decimal(12, 2)    // Full booking amount
  instalmentCount     Int             // 3 or 6
  instalmentAmount    Decimal         @db.Decimal(12, 2)    // Per instalment (may vary for first)
  serviceFeeRate      Decimal         @default(3.5) @db.Decimal(5, 2) // % fee on top of total
  serviceFeeAmount    Decimal         @db.Decimal(12, 2)   // Total fee charged
  grandTotal          Decimal         @db.Decimal(12, 2)   // totalAmount + serviceFeeAmount
  currency            String          @default("NGN")

  // Paystack integration
  paystackAuthCode    String?         // Reusable authorization code from first charge
  paystackCustomerCode String?        // Paystack customer code
  paystackEmail       String?         // Email for recurring charges

  // Status tracking
  status              InstalmentStatus @default(ACTIVE)
  amountPaid          Decimal         @default(0) @db.Decimal(12, 2)
  nextDueDate         DateTime?
  cancelledAt         DateTime?
  cancelReason        String?
  completedAt         DateTime?
  defaultedAt         DateTime?
  failureCount        Int             @default(0)  // consecutive failures

  // First instalment start date
  startDate           DateTime        @default(now())

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  booking   Booking          @relation(fields: [bookingId], references: [id])
  planner   Planner?         @relation(fields: [plannerId], references: [id])
  consumer  Consumer?        @relation(fields: [consumerId], references: [id])
  payments  InstalmentPayment[]

  @@index([bookingId])
  @@index([plannerId])
  @@index([consumerId])
  @@index([status])
  @@index([nextDueDate])
  @@map("instalment_plans")
}

model InstalmentPayment {
  id                  String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  planId              String                  @db.Uuid
  instalmentNumber    Int                     // 1 of 3, 2 of 3, etc.
  amount              Decimal                 @db.Decimal(12, 2)
  dueDate             DateTime
  paidAt              DateTime?
  status              InstalmentPaymentStatus @default(SCHEDULED)

  // Paystack charge details
  paystackReference   String?     @unique
  paystackChargeId    String?
  failureReason       String?
  retryCount          Int         @default(0)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  plan InstalmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([dueDate])
  @@index([status])
  @@map("instalment_payments")
}

