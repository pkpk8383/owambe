{
  "expo": {
    "name": "Owambe",
    "slug": "owambe",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "scheme": "owambe",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.owambe.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Owambe uses your camera to scan QR tickets at events.",
        "NSLocationWhenInUseUsageDescription": "Owambe uses your location to find nearby venues and vendors.",
        "NSPhotoLibraryUsageDescription": "Owambe uses your photo library to upload portfolio and event images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.owambe.app",
      "versionCode": 9,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "Owambe uses your camera to scan event QR codes."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d2c2a124-6fd0-48b4-ae3b-492b763f9a7b"
      },
      "router": {
        "origin": false
      }
    }
  }
}